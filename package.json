{
	"name": "@nomideusz/zaur-world",
	"version": "0.10.0",
	"description": "A living ambient sky for any web page — real sunrise/sunset, live weather, seasons, day/night cycle, and small delights on a single canvas. Zero dependencies.",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./weather": {
			"types": "./dist/weather.d.ts",
			"default": "./dist/weather.js"
		},
		"./solar": {
			"types": "./dist/solar.d.ts",
			"default": "./dist/solar.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"default": "./dist/react.js"
		},
		"./auto": {
			"types": "./dist/auto.d.ts",
			"default": "./dist/auto.js"
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": [
		"./dist/auto.js"
	],
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"build": "tsc -p tsconfig.json && node scripts/minify.mjs",
		"build:types": "tsc -p tsconfig.json",
		"test": "pnpm run build:types && node --test test/*.test.mjs",
		"demo:dev": "pnpm run build:types && pnpm --filter zaur-world-demo dev",
		"demo:build": "pnpm run build && pnpm --filter zaur-world-demo build",
		"prepublishOnly": "pnpm test && pnpm run build"
	},
	"keywords": [
		"canvas",
		"sky",
		"weather",
		"ambient",
		"generative",
		"day-night",
		"sunrise-sunset",
		"open-meteo",
		"background",
		"zaur"
	],
	"author": "nomideusz",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nomideusz/zaur-world.git"
	},
	"homepage": "https://zaur.app",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.1.8",
		"esbuild": "0.25.5",
		"react": "^19.1.0",
		"typescript": "^5.7.2"
	}
}
